# INDIGO INSIGHTS - Configuration Template
# 1. Fill these out
# 2. Save this file as .env
# 3. DO NOT commit .env to GitHub

# --- API KEYS ---
GROQ_API_KEY=your_groq_key_here
PEXELS_API_KEY=your_pexels_key_here

# --- DATABASE (Supabase) ---
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_key

# --- YOUTUBE AUTH ---
# 1. Run the app once locally.
# 2. Copy the contents of token.json.
# 3. Add to GitHub Secrets as YOUTUBE_TOKEN_JSON.
YOUTUBE_TOKEN_JSON=''

# --- OPTIONAL: REDDIT (For auto-topics) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
